{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deepnest.io/ml/run_event.schema.json",
  "title": "Deepnest Run Event",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "job_id",
    "timestamp",
    "stage",
    "status"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "run_id": {
      "type": "string"
    },
    "job_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string"
    },
    "stage": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "started",
        "progress",
        "completed",
        "failed"
      ]
    },
    "message": {
      "type": [
        "string",
        "null"
      ]
    },
    "summary": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
